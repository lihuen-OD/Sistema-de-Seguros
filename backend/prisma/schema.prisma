generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 2 — Catálogos
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  cuit      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies         Policy[]
  assetAllocations AssetAllocation[]

  @@map("companies")
}

model CostCenter {
  id          String   @id @default(uuid())
  name        String
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assetAllocations AssetAllocation[]
  policies         Policy[]

  @@map("cost_centers")
}

model InsuranceType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coverages InsuranceCoverage[]
  policies  Policy[]

  @@map("insurance_types")
}

model InsuranceCoverage {
  id              String        @id @default(uuid())
  name            String
  description     String?
  insuranceTypeId String
  insuranceType   InsuranceType @relation(fields: [insuranceTypeId], references: [id], onDelete: Cascade)

  @@index([insuranceTypeId])
  @@map("insurance_coverages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 3 — Activos (forward references para que Company/CostCenter compilen)
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id            String    @id @default(uuid())
  code           String?  @unique
  name           String
  assetType      String
  status         String   @default("activo")
  fixedAssetCode String?
  brand          String?
  model          String?
  year           Int?
  serialNumber   String?
  purchaseDate           DateTime? @db.Date
  dischargeDate          DateTime? @db.Date
  saleDate               DateTime? @db.Date
  purchaseValue          Float?
  currentValue           Float?
  patrimonialValueNew    Float?
  location       String?
  mapsUrl        String?
  productiveUnit String?
  area           String?
  description    String?
  metadata       Json?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  allocations       AssetAllocation[]
  valueHistory      AssetValueHistory[]
  statusHistory     AssetStatusHistory[]
  attachments       AssetAttachment[]
  fireExtinguishers FireExtinguisher[]
  claims            Claim[]

  @@index([isActive, status])
  @@index([isActive, assetType])
  @@index([name])
  @@index([brand])
  @@map("assets")
}

model AssetStatusHistory {
  id        String   @id @default(uuid())
  assetId   String
  status    String
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_status_history")
}

model AssetAllocation {
  id           String     @id @default(uuid())
  assetId      String
  companyId    String
  costCenterId String
  percentage   Float
  asset        Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company      Company    @relation(fields: [companyId], references: [id])
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])

  @@index([assetId])
  @@index([companyId])
  @@index([costCenterId])
  @@map("asset_allocations")
}

model AssetValueHistory {
  id      String   @id @default(uuid())
  assetId String
  value   Float
  date    DateTime @db.Date
  type    String   @default("real")
  note    String?
  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_value_history")
}

model AssetAttachment {
  id                  String    @id @default(uuid())
  assetId             String
  name                String
  description         String?
  fileType            String
  fileSize            String
  fileUrl             String
  cloudinaryPublicId  String?
  expirationDate      DateTime? @db.Date
  uploadedAt          DateTime  @default(now())
  uploadedBy          String
  asset               Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([expirationDate])
  @@map("asset_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 4 — Productores
// ─────────────────────────────────────────────────────────────────────────────

model Producer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  matricula String?  @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    ProducerTask[]
  policies Policy[]

  @@map("producers")
}

model ProducerTask {
  id          String    @id @default(uuid())
  producerId  String
  title       String
  description String?
  dueDate     DateTime? @db.Date
  status      String    @default("pendiente")
  priority    String    @default("media")
  assignedTo  String?
  policyId    String?
  assetId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  producer    Producer  @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@index([producerId, status])
  @@index([dueDate, status])
  @@index([policyId])
  @@index([assetId])
  @@map("producer_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 5 — Pólizas
// ─────────────────────────────────────────────────────────────────────────────

model Policy {
  id                     String   @id @default(uuid())
  policyNumber           String   @unique
  insuranceTypeId        String
  companyId              String
  costCenterId           String?
  producerId             String?
  insuredName            String
  assetIds               String[]
  beneficiaryDescription String?
  startDate              DateTime @db.Date
  endDate                DateTime @db.Date
  premium                Float
  currency               String   @default("ARS")
  exchangeRate           Float    @default(1)
  description            String?
  coverageIds            String[]
  isActive               Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  insuranceType InsuranceType              @relation(fields: [insuranceTypeId], references: [id])
  company       Company                    @relation(fields: [companyId], references: [id])
  costCenter    CostCenter?                @relation(fields: [costCenterId], references: [id])
  producer      Producer?                  @relation(fields: [producerId], references: [id])
  attachments   PolicyAttachment[]
  allocations   DocumentPolicyAllocation[]
  endorsements  AccountingDocument[]
  claims        Claim[]

  @@index([isActive, endDate])
  @@index([companyId, isActive])
  @@index([insuranceTypeId, isActive])
  @@index([companyId])
  @@index([insuranceTypeId])
  @@index([producerId])
  @@map("policies")
}

model PolicyAttachment {
  id                  String    @id @default(uuid())
  policyId            String
  name                String
  description         String?
  fileType            String
  fileSize            String
  fileUrl             String
  cloudinaryPublicId  String?
  expirationDate      DateTime? @db.Date
  uploadedAt          DateTime  @default(now())
  uploadedBy          String
  policy              Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([expirationDate])
  @@map("policy_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 6 — Documentos Contables
// ─────────────────────────────────────────────────────────────────────────────

model AccountingDocument {
  id               String   @id @default(uuid())
  documentNumber   String
  documentType     String
  documentStatus   String   @default("ISSUED")
  issueDate        DateTime @db.Date
  netAmount        Float
  vatAmount        Float    @default(0)
  otherTaxesAmount Float    @default(0)
  currency         String   @default("ARS")
  exchangeRate     Float    @default(1)
  description      String?
  paymentStatus    String   @default("PENDING")
  insuranceCompany String?
  paymentMethod    String?
  linkedDocumentId String?
  relationType     String?
  adjustmentReason String?
  adjustmentSign   String?

  // Fase 7 — Endoso: se asocia principalmente a una póliza, no a otro documento.
  policyId                 String?
  economicImpactType       String?
  endorsementType          String?
  endorsementEffectiveDate DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installments DocumentInstallment[]
  allocations  DocumentPolicyAllocation[]
  attachments  DocumentAttachment[]
  auditLogs    DocumentAuditLog[]
  policy       Policy?                    @relation(fields: [policyId], references: [id])

  @@index([paymentStatus])
  @@index([issueDate])
  @@index([documentType])
  @@index([documentStatus])
  @@index([policyId])
  @@index([linkedDocumentId])
  @@map("accounting_documents")
}

model DocumentAuditLog {
  id                   String   @id @default(uuid())
  accountingDocumentId String
  action               String // CREATE | UPDATE | APPLY | CANCEL | PAYMENT_CHANGE
  description          String
  previousData         Json?
  newData              Json?
  performedBy          String?
  reason               String?
  createdAt            DateTime @default(now())
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)

  @@index([accountingDocumentId])
  @@map("document_audit_logs")
}

model DocumentInstallment {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  installmentNumber    Int
  dueDate              DateTime @db.Date
  amount               Float
  currency             String   @default("ARS")
  paymentStatus        String   @default("PENDING")
  paymentDate          DateTime? @db.Date
  paymentMethod        String?
  notes                String?
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)

  @@index([accountingDocumentId])
  @@index([paymentStatus, dueDate])
  @@map("document_installments")
}

model DocumentPolicyAllocation {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  policyId             String
  allocatedAmount      Float
  allocationPercentage Float
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)
  policy               Policy             @relation(fields: [policyId], references: [id])

  @@index([accountingDocumentId])
  @@index([policyId])
  @@map("document_policy_allocations")
}

model DocumentAttachment {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  name                 String
  description          String?
  fileType             String
  fileSize             String
  fileUrl              String
  cloudinaryPublicId   String?
  uploadedAt           DateTime           @default(now())
  uploadedBy           String
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)

  @@index([accountingDocumentId])
  @@map("document_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 7 — Matafuegos
// ─────────────────────────────────────────────────────────────────────────────

model FireExtinguisher {
  id                String    @id @default(uuid())
  code              String    @unique
  assetId           String?
  locationType      String
  location          String?
  establishment     String?
  type              String
  capacity          String
  brand             String?
  cylinderNumber    String?
  manufacturingYear Int?
  expirationDate    DateTime  @db.Date
  lastRechargeDate  DateTime? @db.Date
  hydraulicTestExpirationDate DateTime? @db.Date
  observations      String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  asset   Asset?                   @relation(fields: [assetId], references: [id])
  history FireExtinguisherHistory[]
  audits          FireExtinguisherAudit[]
  proposedChanges FireExtinguisherAuditProposedChange[]
  attachments     FireExtinguisherAttachment[]

  @@index([isActive, expirationDate])
  @@index([assetId])
  @@map("fire_extinguishers")
}

// nextDueDate/previousExpirationDate: columnas específicas de recarga (sin cambios).
// description/previousData/newData: diff genérico usado por altas/ediciones/bajas.
// Ambas formas conviven en la misma tabla — un timeline único por matafuego.
model FireExtinguisherHistory {
  id                     String           @id @default(uuid())
  fireExtinguisherId     String
  action                 String
  date                   DateTime         @db.Date
  performedBy            String?
  notes                  String?
  nextDueDate            DateTime?        @db.Date
  previousExpirationDate DateTime?        @db.Date
  description            String?
  previousData           Json?
  newData                Json?
  createdAt              DateTime         @default(now())
  extinguisher           FireExtinguisher @relation(fields: [fireExtinguisherId], references: [id], onDelete: Cascade)

  @@index([fireExtinguisherId])
  @@map("fire_extinguisher_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// Matafuegos Fase 3 — Auditoría mensual
//
// El maestro (FireExtinguisher) es la verdad oficial. Una auditoría NUNCA
// modifica el maestro directamente — cualquier discrepancia detectada por el
// auditor (ubicación o campos de FireExtinguisherAuditProposedChange) queda
// en estado PENDING hasta que una fase futura (revisión/aprobación) la aplique.
// ─────────────────────────────────────────────────────────────────────────────

model FireExtinguisherAudit {
  id                 String   @id @default(uuid())
  fireExtinguisherId String
  status             String   @default("SUBMITTED") // DRAFT | SUBMITTED | APPROVED | REJECTED | NEEDS_CORRECTION
  auditDate          DateTime @db.Date // derivado en el server ("hoy"), nunca confiado del cliente
  auditPeriod        String              // "YYYY-MM", derivado en el server
  auditedBy          String

  // Paso 2 — Validación de ubicación
  locationConfirmed       Boolean @default(true)
  locationChangeRequested Boolean @default(false)
  proposedLocation        String?
  locationChangeReason    String?

  // Paso 4 — Checklist de condición (embebido, sin tabla separada)
  cleanliness                  String
  chargeFillStatus             String // CARGADO | DESCARGADO — no confundir con el status de vencimiento (vigente/proximo_vencer/vencido)
  beaconPlateCondition         String // SANA | ROTA_LEVE | ROTA_REQUIERE_CAMBIO | NO_TIENE
  sealStatus                   String
  ringStatus                   String
  hoseNozzleCondition          String
  chargeExpirationDateObserved DateTime? @db.Date
  comments                     String?

  // Fase 4 — Revisión/aprobación
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extinguisher    FireExtinguisher                      @relation(fields: [fireExtinguisherId], references: [id], onDelete: Cascade)
  proposedChanges FireExtinguisherAuditProposedChange[]
  attachments     FireExtinguisherAttachment[]

  // La unicidad real de (fireExtinguisherId, auditPeriod) NO se modela acá con
  // @@unique — vive en un ÍNDICE ÚNICO PARCIAL creado a mano en la migración
  // 20260707120000_add_fire_extinguisher_audit_review (WHERE status NOT IN
  // ('REJECTED','NEEDS_CORRECTION')), para permitir crear una auditoría nueva
  // del mismo matafuego+período tras una recorrección. Prisma no soporta
  // partial indexes en su DSL — por eso es invisible acá. Mismo patrón que
  // 20260622000003_add_sequential_sequences (SEQUENCEs de Postgres).
  // NO reintroducir @@unique([fireExtinguisherId, auditPeriod]) acá.
  // NO correr `prisma db push` contra esta tabla sin revisar a mano.
  @@index([fireExtinguisherId, auditPeriod])
  @@index([fireExtinguisherId])
  @@map("fire_extinguisher_audits")
}

model FireExtinguisherAuditProposedChange {
  id                 String   @id @default(uuid())
  auditId            String
  fireExtinguisherId String // denormalizado — permite consultar cambios pendientes de una unidad sin pasar por el audit
  fieldName          String // coincide 1:1 con la columna real del maestro: cylinderNumber | expirationDate | capacity | type | brand | location
  currentValue       String
  proposedValue      String
  reason             String?
  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED | APPLIED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  audit        FireExtinguisherAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  extinguisher FireExtinguisher      @relation(fields: [fireExtinguisherId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([fireExtinguisherId])
  @@map("fire_extinguisher_audit_proposed_changes")
}

model FireExtinguisherAttachment {
  id                 String   @id @default(uuid())
  fireExtinguisherId String
  auditId            String?
  name               String
  description        String?
  fileType           String
  fileSize           String
  fileUrl            String
  cloudinaryPublicId String?
  uploadedAt         DateTime @default(now())
  uploadedBy         String

  extinguisher FireExtinguisher       @relation(fields: [fireExtinguisherId], references: [id], onDelete: Cascade)
  audit        FireExtinguisherAudit? @relation(fields: [auditId], references: [id], onDelete: SetNull)

  @@index([fireExtinguisherId])
  @@index([auditId])
  @@map("fire_extinguisher_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 8 — Siniestros
// ─────────────────────────────────────────────────────────────────────────────

model Claim {
  id                         String   @id @default(uuid())
  claimNumber                String   @unique
  assetId                    String?
  policyId                   String?
  claimType                  String
  occurrenceDate             DateTime @db.Date
  reportDate                 DateTime @db.Date
  description                String?
  insuranceCompany           String?
  ownershipType              String   @default("propio")
  responsiblePersonName      String?
  thirdPartyInsuranceCompany String?
  thirdPartyContact          String?
  thirdPartyInsurerContact   String?
  status                     String   @default("denunciado")
  claimedAmountArs           Float    @default(0)
  realAmountArs              Float?
  settledAmountArs           Float?
  deductibleArs              Float?
  currency                   String   @default("ARS")
  exchangeRate               Float    @default(1)
  observations               String?
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  asset       Asset?            @relation(fields: [assetId], references: [id])
  policy      Policy?           @relation(fields: [policyId], references: [id])
  events      ClaimEvent[]
  attachments ClaimAttachment[]
  expenses    ClaimExpense[]

  @@index([isActive, status])
  @@index([isActive, occurrenceDate])
  @@index([policyId])
  @@index([assetId])
  @@index([occurrenceDate])
  @@map("claims")
}

model ClaimExpense {
  id               String   @id @default(uuid())
  claimId          String
  date             DateTime @db.Date
  provider         String
  receiptNumber    String?
  netAmount        Float
  vatAmount        Float    @default(0)
  otherTaxesAmount Float    @default(0)
  createdAt        DateTime @default(now())
  createdBy        String?
  claim            Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_expenses")
}

model ClaimAttachment {
  id                 String    @id @default(uuid())
  claimId            String
  name               String
  description        String?
  fileType           String
  fileSize            String
  fileUrl            String
  cloudinaryPublicId String?
  uploadedAt         DateTime  @default(now())
  uploadedBy         String
  claim              Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_attachments")
}

model ClaimEvent {
  id             String   @id @default(uuid())
  claimId        String
  type           String
  description    String
  date           DateTime @db.Date
  previousStatus String?
  newStatus      String?
  amountLabel    String?
  previousAmount Float?
  newAmount      Float?
  createdBy      String?
  createdAt      DateTime @default(now())
  claim          Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Configuración de Módulos — Catálogos dinámicos
// ─────────────────────────────────────────────────────────────────────────────

model CatalogItem {
  id        String   @id @default(uuid())
  category  String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, label])
  @@index([category])
  @@map("catalog_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Email — Envío transaccional (Resend)
// ─────────────────────────────────────────────────────────────────────────────

model EmailLog {
  id       String @id @default(uuid())
  type     String // MANUAL_DOCUMENT_SEND | EXPIRATION_SUMMARY | ATTACHMENT_EXPIRATION | POLICY_EXPIRATION | FIRE_EXTINGUISHER_EXPIRATION | WORKFLOW_NOTIFICATION | SYSTEM
  status   String @default("PENDING") // PENDING | SENT | FAILED | SKIPPED | CANCELLED
  provider String @default("resend")

  fromAddress  String
  toAddresses  String[]
  ccAddresses  String[] @default([])
  bccAddresses String[] @default([])
  replyTo      String?
  subject      String

  // Referencia polimórfica suelta — un mismo log puede apuntar a distintas
  // tablas (AccountingDocument, Policy, FireExtinguisher, etc.), por eso no
  // hay FK real, solo entityType + entityId.
  entityType String?
  entityId   String?

  triggeredByUserId String?
  triggeredByEmail  String?

  scheduledFor DateTime?
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?

  providerMessageId String?
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([type, status])
  @@map("email_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Autenticación — usuarios propios (reemplaza el auto-login de desarrollo)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String // ADMIN | AUDITOR_MATAFUEGOS | CONTADOR | PRODUCTOR | VIEWER
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  dismissals NotificationDismissal[]

  @@index([role])
  @@map("users")
}

// Notificaciones calculadas en vivo (sin tabla propia) — esto guarda solo
// el "ya lo vi" de cada usuario. La clave incluye dueDate a propósito: si
// el vencimiento real cambia (ej. se renueva una póliza), el descarte viejo
// deja de aplicar y la alerta vuelve a aparecer sin limpiar nada a mano.
model NotificationDismissal {
  id             String   @id @default(uuid())
  userId         String
  notificationId String
  dueDate        String
  dismissedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId, dueDate])
  @@index([userId])
  @@map("notification_dismissals")
}
