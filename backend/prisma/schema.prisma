generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 2 — Catálogos
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  cuit      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies         Policy[]
  assetAllocations AssetAllocation[]

  @@map("companies")
}

model CostCenter {
  id          String   @id @default(uuid())
  name        String
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assetAllocations AssetAllocation[]
  policies         Policy[]

  @@map("cost_centers")
}

model InsuranceType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coverages InsuranceCoverage[]
  policies  Policy[]

  @@map("insurance_types")
}

model InsuranceCoverage {
  id              String        @id @default(uuid())
  name            String
  description     String?
  insuranceTypeId String
  insuranceType   InsuranceType @relation(fields: [insuranceTypeId], references: [id], onDelete: Cascade)

  @@index([insuranceTypeId])
  @@map("insurance_coverages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 3 — Activos (forward references para que Company/CostCenter compilen)
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id            String    @id @default(uuid())
  code           String?  @unique
  name           String
  assetType      String
  status         String   @default("activo")
  fixedAssetCode String?
  brand          String?
  model          String?
  year           Int?
  serialNumber   String?
  purchaseDate           DateTime? @db.Date
  dischargeDate          DateTime? @db.Date
  saleDate               DateTime? @db.Date
  purchaseValue          Float?
  currentValue           Float?
  patrimonialValueNew    Float?
  location       String?
  mapsUrl        String?
  productiveUnit String?
  area           String?
  description    String?
  metadata       Json?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  allocations       AssetAllocation[]
  valueHistory      AssetValueHistory[]
  attachments       AssetAttachment[]
  fireExtinguishers FireExtinguisher[]
  claims            Claim[]

  @@index([isActive, status])
  @@index([isActive, assetType])
  @@index([name])
  @@index([brand])
  @@map("assets")
}

model AssetAllocation {
  id           String     @id @default(uuid())
  assetId      String
  companyId    String
  costCenterId String
  percentage   Float
  asset        Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company      Company    @relation(fields: [companyId], references: [id])
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])

  @@index([assetId])
  @@index([companyId])
  @@index([costCenterId])
  @@map("asset_allocations")
}

model AssetValueHistory {
  id      String   @id @default(uuid())
  assetId String
  value   Float
  date    DateTime @db.Date
  type    String   @default("real")
  note    String?
  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_value_history")
}

model AssetAttachment {
  id                  String    @id @default(uuid())
  assetId             String
  name                String
  description         String?
  fileType            String
  fileSize            String
  fileUrl             String
  cloudinaryPublicId  String?
  expirationDate      DateTime? @db.Date
  notifyEmail         String?
  uploadedAt          DateTime  @default(now())
  uploadedBy          String
  asset               Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 4 — Productores
// ─────────────────────────────────────────────────────────────────────────────

model Producer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  matricula String?  @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    ProducerTask[]
  policies Policy[]

  @@map("producers")
}

model ProducerTask {
  id          String    @id @default(uuid())
  producerId  String
  title       String
  description String?
  dueDate     DateTime? @db.Date
  status      String    @default("pendiente")
  priority    String    @default("media")
  assignedTo  String?
  policyId    String?
  assetId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  producer    Producer  @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@index([producerId, status])
  @@index([dueDate, status])
  @@index([policyId])
  @@index([assetId])
  @@map("producer_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 5 — Pólizas
// ─────────────────────────────────────────────────────────────────────────────

model Policy {
  id                     String   @id @default(uuid())
  policyNumber           String   @unique
  insuranceTypeId        String
  companyId              String
  costCenterId           String?
  producerId             String?
  insuredName            String
  assetId                String?
  beneficiaryDescription String?
  startDate              DateTime @db.Date
  endDate                DateTime @db.Date
  premium                Float
  currency               String   @default("ARS")
  exchangeRate           Float    @default(1)
  description            String?
  coverageIds            String[]
  isActive               Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  insuranceType InsuranceType              @relation(fields: [insuranceTypeId], references: [id])
  company       Company                    @relation(fields: [companyId], references: [id])
  costCenter    CostCenter?                @relation(fields: [costCenterId], references: [id])
  producer      Producer?                  @relation(fields: [producerId], references: [id])
  attachments   PolicyAttachment[]
  allocations   DocumentPolicyAllocation[]
  claims        Claim[]

  @@index([isActive, endDate])
  @@index([companyId, isActive])
  @@index([insuranceTypeId, isActive])
  @@index([companyId])
  @@index([insuranceTypeId])
  @@index([producerId])
  @@index([assetId])
  @@map("policies")
}

model PolicyAttachment {
  id                  String    @id @default(uuid())
  policyId            String
  name                String
  description         String?
  fileType            String
  fileSize            String
  fileUrl             String
  cloudinaryPublicId  String?
  expirationDate      DateTime? @db.Date
  notifyEmail         String?
  uploadedAt          DateTime  @default(now())
  uploadedBy          String
  policy              Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@map("policy_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 6 — Documentos Contables
// ─────────────────────────────────────────────────────────────────────────────

model AccountingDocument {
  id               String   @id @default(uuid())
  documentNumber   String   @unique
  documentType     String
  issueDate        DateTime @db.Date
  netAmount        Float
  vatAmount        Float    @default(0)
  otherTaxesAmount Float    @default(0)
  currency         String   @default("ARS")
  exchangeRate     Float    @default(1)
  description      String?
  paymentStatus    String   @default("pendiente")
  insuranceCompany String?
  paymentMethod    String?
  linkedDocumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installments DocumentInstallment[]
  allocations  DocumentPolicyAllocation[]
  attachments  DocumentAttachment[]

  @@index([paymentStatus])
  @@index([issueDate])
  @@index([documentType])
  @@map("accounting_documents")
}

model DocumentInstallment {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  installmentNumber    Int
  dueDate              DateTime @db.Date
  amount               Float
  currency             String   @default("ARS")
  paymentStatus        String   @default("pendiente")
  paymentDate          DateTime? @db.Date
  paymentMethod        String?
  notes                String?
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)

  @@index([accountingDocumentId])
  @@index([paymentStatus, dueDate])
  @@map("document_installments")
}

model DocumentPolicyAllocation {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  policyId             String
  allocatedAmount      Float
  allocationPercentage Float
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)
  policy               Policy             @relation(fields: [policyId], references: [id])

  @@index([accountingDocumentId])
  @@index([policyId])
  @@map("document_policy_allocations")
}

model DocumentAttachment {
  id                   String             @id @default(uuid())
  accountingDocumentId String
  name                 String
  description          String?
  fileType             String
  fileSize             String
  fileUrl              String
  cloudinaryPublicId   String?
  uploadedAt           DateTime           @default(now())
  uploadedBy           String
  document             AccountingDocument @relation(fields: [accountingDocumentId], references: [id], onDelete: Cascade)

  @@index([accountingDocumentId])
  @@map("document_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 7 — Matafuegos
// ─────────────────────────────────────────────────────────────────────────────

model FireExtinguisher {
  id               String   @id @default(uuid())
  code             String    @unique
  assetId          String?
  locationType     String
  location         String?
  type             String
  capacity         String
  brand            String?
  serialNumber     String?
  expirationDate   DateTime  @db.Date
  lastRechargeDate DateTime? @db.Date
  observations     String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  asset   Asset?                   @relation(fields: [assetId], references: [id])
  history FireExtinguisherHistory[]

  @@index([isActive, expirationDate])
  @@index([assetId])
  @@map("fire_extinguishers")
}

model FireExtinguisherHistory {
  id                     String           @id @default(uuid())
  fireExtinguisherId     String
  action                 String
  date                   DateTime         @db.Date
  performedBy            String?
  notes                  String?
  nextDueDate            DateTime?        @db.Date
  previousExpirationDate DateTime?        @db.Date
  createdAt              DateTime         @default(now())
  extinguisher           FireExtinguisher @relation(fields: [fireExtinguisherId], references: [id], onDelete: Cascade)

  @@index([fireExtinguisherId])
  @@map("fire_extinguisher_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 8 — Siniestros
// ─────────────────────────────────────────────────────────────────────────────

model Claim {
  id               String   @id @default(uuid())
  claimNumber      String   @unique
  assetId          String?
  policyId         String?
  claimType        String
  occurrenceDate   DateTime @db.Date
  reportDate       DateTime @db.Date
  description      String?
  insuranceCompany String?
  status           String   @default("denunciado")
  claimedAmountArs Float    @default(0)
  realAmountArs    Float?
  settledAmountArs Float?
  deductibleArs    Float?
  currency         String   @default("ARS")
  exchangeRate     Float    @default(1)
  observations     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  asset       Asset?            @relation(fields: [assetId], references: [id])
  policy      Policy?           @relation(fields: [policyId], references: [id])
  events      ClaimEvent[]
  attachments ClaimAttachment[]

  @@index([isActive, status])
  @@index([isActive, occurrenceDate])
  @@index([policyId])
  @@index([assetId])
  @@index([occurrenceDate])
  @@map("claims")
}

model ClaimAttachment {
  id                 String    @id @default(uuid())
  claimId            String
  name               String
  description        String?
  fileType           String
  fileSize            String
  fileUrl            String
  cloudinaryPublicId String?
  uploadedAt         DateTime  @default(now())
  uploadedBy         String
  claim              Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_attachments")
}

model ClaimEvent {
  id             String   @id @default(uuid())
  claimId        String
  type           String
  description    String
  date           DateTime @db.Date
  previousStatus String?
  newStatus      String?
  amountLabel    String?
  previousAmount Float?
  newAmount      Float?
  createdBy      String?
  createdAt      DateTime @default(now())
  claim          Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Configuración de Módulos — Catálogos dinámicos
// ─────────────────────────────────────────────────────────────────────────────

model CatalogItem {
  id        String   @id @default(uuid())
  category  String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("catalog_items")
}
