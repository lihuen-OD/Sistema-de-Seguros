# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                 # opcional (default: development) — usar "production" en el deploy real
PORT=3001                            # opcional (default: 3001)
FRONTEND_URL=http://localhost:5173   # opcional (default: http://localhost:5173) — URL real del frontend en producción (CORS)

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection (para runtime) — REQUERIDO
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true
# Direct connection (para migraciones Prisma) — opcional, pero requerido en la práctica
# para correr `prisma migrate deploy` contra Neon (el pooler no soporta el protocolo de migración)
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUERIDO — mínimo 32 caracteres. Generá un secreto con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-real-random-secret-minimum-32-chars-here

# ─── Seed del primer usuario ADMIN ────────────────────────────────────────────
# Todos opcionales — solo se usan para crear el primer usuario si la tabla users está vacía.
# Cambiar la contraseña en el primer login — no usar estos valores en producción.
SEED_ADMIN_EMAIL=admin@losodwyer.com
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_NAME=Administrador          # opcional (default: Administrador)

# ─── File Storage (Cloudinary) ────────────────────────────────────────────────
# Opcionales — sin las 3 configuradas, la subida de archivos queda deshabilitada
# (responde 503 STORAGE_NOT_CONFIGURED) en vez de romper el arranque del servidor.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opcional — prefijo de carpeta por ambiente (ej. "demo", "staging"). Sin
# setear, no se antepone nada. Útil si un ambiente de pruebas comparte la
# misma cuenta de Cloudinary que producción, para no mezclar los archivos.
CLOUDINARY_ROOT_FOLDER=

# ─── Email (Resend) — Envío transaccional ────────────────────────────────────
EMAIL_PROVIDER=resend                  # opcional (default: resend)
EMAIL_ENABLED=true                     # opcional (default: false) — en false, los emails no se envían (se loguean)
RESEND_API_KEY=                        # requerido solo si EMAIL_ENABLED=true

EMAIL_FROM_DEFAULT="Sistema Seguros <notificaciones@losodwyer.com>"     # opcional (tiene default)
EMAIL_FROM_NOTIFICATIONS="Sistema Seguros <notificaciones@losodwyer.com>" # opcional (tiene default)
EMAIL_FROM_MANUAL="Sistema Seguros <seguros@losodwyer.com>"             # opcional (tiene default)

# Opcional — de setearse, TODOS los emails salientes se redirigen a esta
# dirección en vez de a sus destinatarios reales. Solo para demo/staging:
# si queda cargada en producción por error, el sistema arranca igual pero
# avisa fuerte en los logs de arranque.
EMAIL_FORCE_TO=
EMAIL_LOG_BODY=false                   # opcional (default: false)
