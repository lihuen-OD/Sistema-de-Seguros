# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection (para runtime)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true
# Direct connection (para migraciones Prisma)
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generá un secreto con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-real-random-secret-minimum-32-chars-here

# ─── File Storage (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Resend) — Envío transaccional ────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_ENABLED=true
RESEND_API_KEY=

EMAIL_FROM_DEFAULT="Sistema Seguros <notificaciones@losodwyer.com>"
EMAIL_FROM_NOTIFICATIONS="Sistema Seguros <notificaciones@losodwyer.com>"
EMAIL_FROM_MANUAL="Sistema Seguros <seguros@losodwyer.com>"

EMAIL_FORCE_TO=
EMAIL_LOG_BODY=false
